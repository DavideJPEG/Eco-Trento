-- Abilita il supporto alle chiavi esterne (fondamentale in SQLite)
PRAGMA foreign_keys = ON;

-- Pulizia iniziale (esegue il drop in ordine inverso per i vincoli)
DROP TABLE IF EXISTS POSIZIONE_LIVE_CAMION;
DROP TABLE IF EXISTS RITIRO_INGOMBRANTI;
DROP TABLE IF EXISTS NOTIFICHE;
DROP TABLE IF EXISTS SEGNALAZIONI;
DROP TABLE IF EXISTS CALENDARI;
DROP TABLE IF EXISTS ISOLE_ECOLOGICHE;
DROP TABLE IF EXISTS UTENTI;
DROP TABLE IF EXISTS VIE;
DROP TABLE IF EXISTS QUARTIERI;

-- 1. Tabella QUARTIERI
CREATE TABLE QUARTIERI (
    ID_Quartiere INTEGER PRIMARY KEY AUTOINCREMENT,
    Nome TEXT NOT NULL UNIQUE,
    Confini_Geo TEXT -- SQLite non ha POLYGON, usiamo TEXT per le coordinate
);

-- 2. Tabella VIE
CREATE TABLE VIE (
    ID_Via INTEGER PRIMARY KEY AUTOINCREMENT,
    Nome_Via TEXT NOT NULL,
    ID_Quartiere INTEGER,
    FOREIGN KEY (ID_Quartiere) REFERENCES QUARTIERI(ID_Quartiere) 
    ON DELETE RESTRICT
);

-- 3. Tabella UTENTI
CREATE TABLE UTENTI (
    ID_Utente INTEGER PRIMARY KEY AUTOINCREMENT,
    Nome TEXT NOT NULL,
    Cognome TEXT NOT NULL,
    Email TEXT NOT NULL UNIQUE,
    Password_Hash TEXT NOT NULL,
    Codice_Fiscale TEXT NOT NULL UNIQUE,
    -- SQLite non ha ENUM, si usa CHECK
    Ruolo TEXT CHECK(Ruolo IN ('Cittadino', 'Operatore', 'Admin')) DEFAULT 'Cittadino',
    ID_Via INTEGER,
    Lingua TEXT DEFAULT 'IT',
    FOREIGN KEY (ID_Via) REFERENCES VIE(ID_Via) 
    ON DELETE SET NULL
);

-- 4. Tabella ISOLE_ECOLOGICHE
CREATE TABLE ISOLE_ECOLOGICHE (
    ID_Isola INTEGER PRIMARY KEY AUTOINCREMENT,
    ID_Via INTEGER,
    Latitudine REAL NOT NULL,
    Longitudine REAL NOT NULL,
    Livello_Riempimento INTEGER CHECK (Livello_Riempimento BETWEEN 0 AND 100),
    Stato_Servizio TEXT CHECK(Stato_Servizio IN ('Attiva', 'Guasta', 'Piena')) DEFAULT 'Attiva',
    Data_Ultimo_Svuotamento TEXT, -- SQLite usa TEXT per le date (ISO8601)
    FOREIGN KEY (ID_Via) REFERENCES VIE(ID_Via) 
    ON DELETE RESTRICT
);

-- 5. Tabella CALENDARI
CREATE TABLE CALENDARI (
    ID_Calendario INTEGER PRIMARY KEY AUTOINCREMENT,
    ID_Via INTEGER,
    Giorno_Settimana TEXT CHECK(Giorno_Settimana IN ('Lunedì', 'Martedì', 'Mercoledì', 'Giovedì', 'Venerdì', 'Sabato', 'Domenica')),
    Tipo_Rifiuto TEXT,
    Orario_Inizio TEXT, -- Formato HH:MM
    Orario_Fine TEXT,
    FOREIGN KEY (ID_Via) REFERENCES VIE(ID_Via) 
    ON DELETE CASCADE
);

-- 6. Tabella SEGNALAZIONI
CREATE TABLE SEGNALAZIONI (
    ID_Segnalazione INTEGER PRIMARY KEY AUTOINCREMENT,
    ID_Utente INTEGER,
    Tipo TEXT CHECK(Tipo IN ('Abbandono', 'Isola_Guasta', 'Ritardo_Camion', 'Altro')),
    Descrizione TEXT,
    Latitudine REAL,
    Longitudine REAL,
    Foto_URL TEXT,
    Stato TEXT CHECK(Stato IN ('Aperta', 'In_Lavorazione', 'Chiusa')) DEFAULT 'Aperta',
    Data_Creazione TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (ID_Utente) REFERENCES UTENTI(ID_Utente) 
    ON DELETE SET NULL
);

-- 7. Tabella NOTIFICHE
CREATE TABLE NOTIFICHE (
    ID_Notifica INTEGER PRIMARY KEY AUTOINCREMENT,
    ID_Utente INTEGER,
    ID_Segnalazione_Rif INTEGER,
    Titolo TEXT,
    Messaggio TEXT,
    Letta BOOLEAN DEFAULT 0, -- 0 = False, 1 = True
    Data_Invio TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (ID_Utente) REFERENCES UTENTI(ID_Utente) 
    ON DELETE CASCADE,
    FOREIGN KEY (ID_Segnalazione_Rif) REFERENCES SEGNALAZIONI(ID_Segnalazione) 
    ON DELETE CASCADE
);

-- 8. Tabella RITIRO_INGOMBRANTI
CREATE TABLE RITIRO_INGOMBRANTI (
    ID_Ritiro INTEGER PRIMARY KEY AUTOINCREMENT,
    ID_Utente INTEGER,
    ID_Via INTEGER,
    Descrizione_Oggetti TEXT,
    Data_Richiesta TEXT,
    Data_Appuntamento TEXT,
    Stato TEXT CHECK(Stato IN ('In_Attesa', 'Confermato', 'Ritirato', 'Annullato')) DEFAULT 'In_Attesa',
    FOREIGN KEY (ID_Utente) REFERENCES UTENTI(ID_Utente) 
    ON DELETE RESTRICT,
    FOREIGN KEY (ID_Via) REFERENCES VIE(ID_Via) 
    ON DELETE RESTRICT
);

-- 9. Tabella POSIZIONE_LIVE_CAMION
CREATE TABLE POSIZIONE_LIVE_CAMION (
    ID_Camion INTEGER PRIMARY KEY AUTOINCREMENT,
    Targa TEXT UNIQUE,
    ID_Quartiere_Attuale INTEGER,
    Latitudine REAL,
    Longitudine REAL,
    Ultimo_Update TEXT DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (ID_Quartiere_Attuale) REFERENCES QUARTIERI(ID_Quartiere) 
    ON DELETE SET NULL
);



